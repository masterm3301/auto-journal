# Postgres connection string (Neon in production). Leave unset locally to use
# the embedded PGlite database stored in .pglite/
DATABASE_URL=

# Claude API key used by the rewrite pipeline (required for /api/cron/ingest)
ANTHROPIC_API_KEY=

# Password for the /admin panel
ADMIN_PASSWORD=change-me

# Shared secret the cron scheduler sends as "Authorization: Bearer <secret>"
CRON_SECRET=change-me-too
